INPUT_DIR=./input_docs
OBSIDIAN_VAULT_DIR=./obsidian_vault
OBSIDIAN_NOTES_SUBDIR=AI-Knowledge
SQLITE_PATH=./knowledge.db

# Parsing pipeline settings
PARSER_ORDER=mineru,paddleocr
PARSER_TIMEOUT_SECONDS=120
FALLBACK_PARSER_ENABLED=true
LARGE_PDF_PAGE_THRESHOLD=300
PDF_BATCH_PAGES=50

# Chart extraction strategy: none/deplot/unichart
CHART_EXTRACTOR=none
CHART_MIN_CHARS=80

# LLM settings
LLM_PROVIDER=none
LLM_ENABLED=false
LLM_API_KEY=
LLM_BASE_URL=
OLLAMA_NATIVE_URL=http://localhost:11434/api/generate
LLM_MODEL=qwen2.5-coder:14b
LLM_TIMEOUT_SECONDS=120
MAX_CHARS_FOR_ANALYSIS=8000
AI_CHUNK_SIZE_CHARS=6000
AI_CHUNK_OVERLAP_CHARS=600
AI_MAX_CHUNKS=120

