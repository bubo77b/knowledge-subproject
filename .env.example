# OmniParser Configuration

# Directories
INPUT_DIR=./input
OUTPUT_DIR=./output

# GPU
GPU_MEMORY_LIMIT_MB=14000
GPU_MONITOR_INTERVAL_SEC=2

# Batch processing
MAX_WORKERS=2

# LLM post-processing (optional)
LLM_ENABLED=false
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3

# Logging
LOG_LEVEL=INFO
LOG_FILE=omniparser.log
